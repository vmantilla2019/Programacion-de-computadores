num=float(input("Número para multiplicar: "))
print(multiplicar_lista(lista,num))

nums=input("Ingrese números para hallar el mayor, separados por espacios")
nums=list(map(float,nums.split()))
print("Mayor:", mayor_de_varios_numeros(*nums))

nums=input("Ingrese números para la mediana: ")
nums=list(map(float,nums.split()))
