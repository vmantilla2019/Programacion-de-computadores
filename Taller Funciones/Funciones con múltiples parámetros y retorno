def promedio(*numeros):
    return sum(numeros)/len(numeros)

def multiplicar_lista(lista,numero):
    nueva=[]
    for i in lista:
        nueva.append(i*numero)
    return nueva

def mayor_de_varios_numeros(*numeros):
    return max(numeros)

def calcular_mediana(*numeros):
    lista=sorted(numeros)
    n=len(lista)

    if n%2==1:
        return lista[n//2]
    else:
        return (lista[n//2-1]+lista[n//2])/2

def contar_ocurrencias(cadena,palabra):
    return cadena.count(palabra)


nums=input("Ingrese números para promedio separados por espacio: ")
nums=list(map(float,nums.split()))
print("Promedio:", promedio(*nums))

