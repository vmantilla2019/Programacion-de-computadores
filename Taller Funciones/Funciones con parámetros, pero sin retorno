def palindromo(palabra):
    if palabra == palabra[::-1]:
        print(True)
    else:
        print(False)

def calcular_potencia(base, exponente):
    resultado = base ** exponente
    print("Resultado:", resultado)

def calcular_media(lista):
    media = sum(lista) / len(lista)
    print("Media:", media)



palabra_usuario = input("Ingrese una palabra: ")
palindromo(palabra_usuario)

base = float(input("Ingrese la base: "))
exponente = float(input("Ingrese el exponente: "))
calcular_potencia(base, exponente)

numeros = input("Ingrese números separados por espacio: ")
lista_numeros = list(map(float, numeros.split()))
calcular_media(lista_numeros)